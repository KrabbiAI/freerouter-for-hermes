# Hermes Agent .env — Template
# Kopiere diese Datei nach ~/.hermes/.env und fülle die Werte aus.

# =============================================================================
# LLM PROVIDER (OpenRouter) — REQUIRED
# =============================================================================
# OpenRouter bietet Zugang zu vielen Modellen über eine API.
# Hol dir deinen Key unter: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-DEIN_KEY_HIER

# =============================================================================
# TELEGRAM BOT — OPTIONAL (für Benachrichtigungen)
# =============================================================================
# Bot Token vom @BotFather: https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_HOME_CHANNEL=123456789

# =============================================================================
# MINIMAX — OPTIONAL (für TTS)
# =============================================================================
# MINIMAX_API_KEY=sk-cp-DEIN_KEY_HIER
